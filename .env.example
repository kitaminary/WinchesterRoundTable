# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection string (takes priority over individual PG* vars below).
DATABASE_URL=postgres://winchester:changeme@localhost:5432/winchester

# Or set individual vars (used when DATABASE_URL is not set):
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=winchester
# PGUSER=winchester
# PGPASSWORD=changeme

# Docker Compose: password for the managed postgres container
POSTGRES_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
# Change this string to start a fresh isolated chat history.
# Old version rows remain in the DB but are no longer served.
CHAT_HISTORY_VERSION=1

# Optional registration invite code. Leave empty to disable.
# When set, /api/auth/register requires the inviteCode field to match.
INVITE_CODE=

# ── Docker tunnel (optional) ──────────────────────────────────────────────────
# Bore tunnel is OFF by default. Set ENABLE_BORE=1 to turn it on.
# When using ngrok instead, leave ENABLE_BORE=0 and run ngrok separately.
# ENABLE_BORE=0
# BORE_SERVER=bore.pub
# NGROK_AUTHTOKEN=

# ── WebRTC TURN relay (optional but recommended for NAT/mobile users) ─────────
# Without TURN, peers behind strict NAT or mobile networks may not connect.
# Get free credentials at https://metered.ca or run your own coturn server.
# VITE_TURN_URL=turn:your-turn-server:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential

# ── Room limits ───────────────────────────────────────────────────────────────
# Max concurrent users (0 = unlimited). Set to expected group size.
# MAX_ROOM_SIZE=13

# ── Dev stack ─────────────────────────────────────────────────────────────────
DEV_CLIENT_PORT=5173
# DEV_SERVER_PORT=3000

# WebRTC TURN relay (optional, recommended for NAT/mobile users)
# Without TURN, peers behind strict NAT or mobile networks may fail to connect.
# Free credentials: https://metered.ca  or run coturn yourself.
# VITE_TURN_URL=turn:your-turn-server:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential

# Room size limit (0 = unlimited)
# MAX_ROOM_SIZE=13
