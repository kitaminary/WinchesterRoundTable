# Server port
PORT=3000

# Chat history version — change this to start a fresh isolated history.
# Old versions are preserved in the database.
CHAT_HISTORY_VERSION=1


# Path where the SQLite database file is stored (default: ./data)
DATA_DIR=./data

# Docker: public tunnel via bore (default relay bore.pub). If your network blocks it, use:
# ENABLE_BORE=0
# Or point BORE_SERVER at a self-hosted bore relay you can reach.
# ENABLE_BORE=1
# BORE_SERVER=bore.pub

# Docker dev stack (`make up-dev` or `docker compose --profile dev up winchester-dev`):
# App UI (Vite HMR): http://localhost:5173 — API/Socket from browser still use host port DEV_SERVER_PORT (default 3000).
# Stop the prod container if 3000 is already in use, or set e.g. DEV_SERVER_PORT=3001 and VITE_SOCKET_URL=http://localhost:3001 in client/.env.local
# DEV_CLIENT_PORT=5173
# DEV_SERVER_PORT=3000
